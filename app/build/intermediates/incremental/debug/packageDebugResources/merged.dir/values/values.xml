    <style name="AnswerOptionStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="strokeColor">@color/border_light</item>
    </style>
    <style name="AnswerOptionStyle.Correct" parent="AnswerOptionStyle">
        <item name="android:backgroundTint">@color/color_correct_light</item>
        <item name="strokeColor">@color/color_correct</item>
        <item name="android:textColor">@color/color_correct</item>
    </style>
    <style name="AnswerOptionStyle.Selected" parent="AnswerOptionStyle">
        <item name="android:backgroundTint">@color/surface_overlay</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
    </style>
    <style name="AnswerOptionStyle.Wrong" parent="AnswerOptionStyle">
        <item name="android:backgroundTint">@color/color_wrong_light</item>
        <item name="strokeColor">@color/color_wrong</item>
        <item name="android:textColor">@color/color_wrong</item>
    </style>
    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="itemTextColor">@drawable/nav_item_color</item>
        <item name="itemIconTint">@drawable/nav_item_color</item>
    </style>
    <style name="ButtonStyle.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
